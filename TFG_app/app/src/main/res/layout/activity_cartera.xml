<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <!-- Icon: Wallet or money -->
    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_wallet"
        android:contentDescription="Icono de cartera" />

    <!-- Big Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mi Cartera / Cobros"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp"
        android:textAlignment="center" />

    <!-- Descriptive Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Para poder recibir el dinero de las plazas que alquiles, necesitas conectar tu cuenta bancaria de forma segura a través de Stripe."
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginBottom="32dp" />

    <!-- ProgressBar for loading state -->
    <ProgressBar
        android:id="@+id/progressBarStripe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

    <!-- Big Eye-Catching Button -->
    <Button
        android:id="@+id/btnConfigurarStripe"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Configurar cuenta de cobros"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#6200EE"
        android:textColor="@android:color/white" />

</LinearLayout>